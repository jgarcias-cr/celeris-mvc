{
   "name": "celeris/mvc",
   "description": "Celeris MVC base application scaffold for building server-rendered web applications.",
   "type": "project",
   "require": {
      "php": ">=8.4",
      "celeris/framework": "*"
   },
   "suggest": {
      "twig/twig": "Template engine support for VIEW_ENGINE=twig.",
      "league/plates": "Template engine support for VIEW_ENGINE=plates.",
      "latte/latte": "Template engine support for VIEW_ENGINE=latte."
   },
   "autoload": {
      "psr-4": {
         "App\\": "app/"
      }
   },
   "scripts": {
      "assets:build": "npm run build",
      "assets:dev": "npm run dev",
      "assets:watch": "npm run watch",
      "post-create-project-cmd": [
         "@php -r \"echo 'Next step: run npm install && npm run build to compile frontend assets.' . PHP_EOL;\""
      ]
   }
}
