# Valid values: any non-empty string (quote when it contains spaces)
APP_NAME="Celeris MVC"

# Valid values: environment label string (for example: development,local,staging,production)
APP_ENV=development

# Valid values: true|false (also accepts 1|0, yes|no, on|off)
APP_DEBUG=true

# Valid values: absolute URL (for example: http://localhost, https://example.com)
APP_URL=http://localhost

# Valid values: any PHP-supported timezone identifier (for example: UTC, America/New_York)
APP_TIMEZONE=UTC

# Valid values: semantic version-like string (for example: 1.0.0)
APP_VERSION=1.0.0

# Valid values: php|twig|plates|latte
VIEW_ENGINE=php

# Valid values: relative or absolute directory path to views
VIEW_PATH=app/Views

# Valid values: file extension without leading dot (for example: php)
VIEW_PHP_EXTENSION=php

# Valid values: file extension without leading dot (for example: twig)
VIEW_TWIG_EXTENSION=twig

# Valid values: file extension without leading dot (for example: php)
VIEW_PLATES_EXTENSION=php

# Valid values: file extension without leading dot (for example: latte)
VIEW_LATTE_EXTENSION=latte

# Valid values: relative or absolute cache path for Twig
VIEW_TWIG_CACHE_PATH=var/cache/twig

# Valid values: true|false (also accepts 1|0, yes|no, on|off)
VIEW_TWIG_AUTO_RELOAD=true

# Valid values: true|false (also accepts 1|0, yes|no, on|off)
VIEW_TWIG_DEBUG=false

# Valid values: relative or absolute temp directory path for Latte
VIEW_LATTE_TEMP_PATH=var/cache/latte

# Valid values: configured connection name main|mysql|mariadb|pgsql|sqlsrv|firebird|ibm|oci
DB_DEFAULT=main

# Valid values: relative or absolute SQLite file path
DB_SQLITE_PATH=var/database.sqlite

# Valid values: hostname or IP
MYSQL_HOST=127.0.0.1

# Valid values: integer 1..65535
MYSQL_PORT=3306

# Valid values: database name string
MYSQL_DATABASE=app

# Valid values: username string
MYSQL_USERNAME=root

# Valid values: password string (empty allowed)
MYSQL_PASSWORD=

# Valid values: hostname or IP
MARIADB_HOST=127.0.0.1

# Valid values: integer 1..65535
MARIADB_PORT=3306

# Valid values: database name string
MARIADB_DATABASE=app

# Valid values: username string
MARIADB_USERNAME=root

# Valid values: password string (empty allowed)
MARIADB_PASSWORD=

# Valid values: hostname or IP
PGSQL_HOST=127.0.0.1

# Valid values: integer 1..65535
PGSQL_PORT=5432

# Valid values: database name string
PGSQL_DATABASE=app

# Valid values: username string
PGSQL_USERNAME=postgres

# Valid values: password string (empty allowed)
PGSQL_PASSWORD=

# Valid values: hostname or IP
SQLSRV_HOST=127.0.0.1

# Valid values: integer 1..65535
SQLSRV_PORT=1433

# Valid values: database name string
SQLSRV_DATABASE=app

# Valid values: username string
SQLSRV_USERNAME=sa

# Valid values: password string (empty allowed)
SQLSRV_PASSWORD=

# Valid values: hostname or IP
FIREBIRD_HOST=127.0.0.1

# Valid values: integer 1..65535
FIREBIRD_PORT=3050

# Valid values: Firebird database path or alias string
FIREBIRD_DATABASE=/var/lib/firebird/data/app.fdb

# Valid values: username string
FIREBIRD_USERNAME=SYSDBA

# Valid values: password string
FIREBIRD_PASSWORD=masterkey

# Valid values: Firebird charset (for example: UTF8, WIN1252)
FIREBIRD_CHARSET=UTF8

# Valid values: empty (auto DSN) or full PDO DSN string (for example: firebird:dbname=127.0.0.1/3050:/var/lib/firebird/data/app.fdb;charset=UTF8)
FIREBIRD_DSN=

# Valid values: auto|identity|sequence|none
FIREBIRD_ID_STRATEGY=auto

# Valid values: empty or exact sequence name (for example: CONTACTS_ID_SEQ)
FIREBIRD_ID_SEQUENCE=

# Valid values: empty or pattern with tokens {table}, {column}, {property} (for example: {table}_{column}_seq)
FIREBIRD_ID_SEQUENCE_PATTERN=

# Valid values: hostname or IP
IBM_HOST=127.0.0.1

# Valid values: integer 1..65535
IBM_PORT=50000

# Valid values: DB2 database name (for example: SAMPLE)
IBM_DATABASE=SAMPLE

# Valid values: username string
IBM_USERNAME=db2inst1

# Valid values: password string (empty allowed)
IBM_PASSWORD=

# Valid values: DB2 protocol string (typically TCPIP)
IBM_PROTOCOL=TCPIP

# Valid values: empty (auto DSN) or full PDO DSN string (for example: ibm:DATABASE=SAMPLE;HOSTNAME=127.0.0.1;PORT=50000;PROTOCOL=TCPIP;)
IBM_DSN=

# Valid values: auto|identity|sequence|none
IBM_ID_STRATEGY=auto

# Valid values: empty or exact sequence name (for example: CONTACTS_ID_SEQ)
IBM_ID_SEQUENCE=

# Valid values: empty or pattern with tokens {table}, {column}, {property} (for example: {table}_{column}_seq)
IBM_ID_SEQUENCE_PATTERN=

# Valid values: hostname or IP
OCI_HOST=127.0.0.1

# Valid values: integer 1..65535
OCI_PORT=1521

# Valid values: Oracle service/connect identifier fallback (for example: XE, ORCLCDB)
OCI_DATABASE=XE

# Valid values: empty or Oracle service name (preferred over OCI_DATABASE when host is used)
OCI_SERVICE_NAME=

# Valid values: empty or Oracle SID (used when set; if both are set, SID is used)
OCI_SID=

# Valid values: username string
OCI_USERNAME=system

# Valid values: password string (empty allowed)
OCI_PASSWORD=

# Valid values: Oracle charset (for example: AL32UTF8)
OCI_CHARSET=AL32UTF8

# Valid values: empty (auto DSN) or full PDO DSN string (for example: oci:dbname=//127.0.0.1:1521/XE;charset=AL32UTF8)
OCI_DSN=

# Valid values: auto|identity|sequence|none
OCI_ID_STRATEGY=auto

# Valid values: empty or exact sequence name (for example: CONTACTS_ID_SEQ)
OCI_ID_SEQUENCE=

# Valid values: empty or pattern with tokens {table}, {column}, {property} (for example: {table}_{column}_seq)
OCI_ID_SEQUENCE_PATTERN=

# Valid values: true|false (also accepts 1|0, yes|no, on|off)
SECURITY_AUTH_JWT_ENABLED=false

# Valid values: true|false (also accepts 1|0, yes|no, on|off)
SECURITY_AUTH_OPAQUE_ENABLED=false

# Valid values: true|false (also accepts 1|0, yes|no, on|off)
SECURITY_AUTH_COOKIE_SESSION_ENABLED=false

# Valid values: true|false (also accepts 1|0, yes|no, on|off)
SECURITY_AUTH_API_TOKEN_ENABLED=false

# Valid values: true|false (also accepts 1|0, yes|no, on|off)
SECURITY_AUTH_MTLS_ENABLED=false

# Valid values: true|false (also accepts 1|0, yes|no, on|off)
SECURITY_CSRF_ENABLED=true

# Valid values: integer >= 1 (requests allowed per window)
SECURITY_RATE_LIMIT_LIMIT=120

# Valid values: integer >= 1 (window duration in seconds)
SECURITY_RATE_LIMIT_WINDOW_SECONDS=60

# Valid values: integer >= 0 (extra burst capacity)
SECURITY_RATE_LIMIT_BURST=0

# Valid values: empty (JWT disabled/not used) or strong secret string (required when JWT auth is enabled)
JWT_SECRET=

# Valid values: integer >= 0 (clock skew tolerance in seconds)
JWT_LEEWAY_SECONDS=30

# Valid values: notification channel name (null by default in core)
NOTIFICATIONS_DEFAULT_CHANNEL=null

# Valid values: true|false (enable/disable sink channel)
NOTIFICATIONS_NULL_ENABLED=true

# Valid values: true|false
NOTIFICATIONS_SMTP_ENABLED=false

# Valid values: hostname or IP
NOTIFICATIONS_SMTP_HOST=127.0.0.1

# Valid values: integer 1..65535
NOTIFICATIONS_SMTP_PORT=587

# Valid values: SMTP username string (empty allowed)
NOTIFICATIONS_SMTP_USERNAME=

# Valid values: SMTP password string (empty allowed)
NOTIFICATIONS_SMTP_PASSWORD=

# Valid values: tls|ssl|starttls|none
NOTIFICATIONS_SMTP_ENCRYPTION=tls

# Valid values: integer >= 1
NOTIFICATIONS_SMTP_TIMEOUT_SECONDS=10

# Valid values: EHLO domain/hostname sent to SMTP server
NOTIFICATIONS_SMTP_EHLO_DOMAIN=localhost

# Valid values: sender email address
NOTIFICATIONS_FROM_ADDRESS=no-reply@example.com

# Valid values: sender display name
NOTIFICATIONS_FROM_NAME=Celeris

# Valid values: true|false
NOTIFICATIONS_IN_APP_ENABLED=false

# Valid values: database connection name (empty = database.default)
NOTIFICATIONS_IN_APP_CONNECTION=

# Valid values: SQL-safe table name
NOTIFICATIONS_IN_APP_TABLE=app_notifications

# Valid values: true|false
NOTIFICATIONS_IN_APP_AUTO_CREATE_TABLE=false

# Valid values: true|false
NOTIFICATIONS_OUTBOX_ENABLED=false

# Valid values: database connection name (empty = database.default)
NOTIFICATIONS_OUTBOX_CONNECTION=

# Valid values: SQL-safe table name
NOTIFICATIONS_OUTBOX_TABLE=notification_outbox

# Valid values: true|false
NOTIFICATIONS_OUTBOX_AUTO_CREATE_TABLE=false

# Valid values: integer >= 1
NOTIFICATIONS_OUTBOX_MAX_ATTEMPTS=5

# Valid values: integer >= 0
NOTIFICATIONS_OUTBOX_BACKOFF_MS=500

# Valid values: integer >= 1
NOTIFICATIONS_OUTBOX_CLAIM_BATCH_SIZE=100

# Valid values: integer >= 1
NOTIFICATIONS_OUTBOX_CLAIM_LOCK_SECONDS=30

# Valid values: true|false
NOTIFICATIONS_REALTIME_ENABLED=false

# Valid values: absolute endpoint URL for websocket gateway publish API
NOTIFICATIONS_REALTIME_ENDPOINT=

# Valid values: integer >= 1
NOTIFICATIONS_REALTIME_TIMEOUT_SECONDS=5

# Valid values: service identifier used for HMAC auth header
NOTIFICATIONS_REALTIME_SERVICE_ID=

# Valid values: shared secret used to sign realtime publish requests
NOTIFICATIONS_REALTIME_SERVICE_SECRET=

# Valid values: true|false
NOTIFICATIONS_DISPATCH_WORKER_ENABLED=false

# Valid values: worker identifier for claim ownership
NOTIFICATIONS_DISPATCH_WORKER_ID=dispatch-worker

# Valid values: integer >= 0
NOTIFICATIONS_DISPATCH_WORKER_IDLE_SLEEP_MS=250

# Valid values: integer >= 1
NOTIFICATIONS_RETRY_MAX_ATTEMPTS=1

# Valid values: integer >= 0
NOTIFICATIONS_RETRY_BACKOFF_MS=250
