# Application identity and runtime mode used by bootstrap, logging, and diagnostics.
APP_NAME="Celeris MVC"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC
APP_VERSION=1.0.0

# View engine and template path settings. Keep extension/cache fields aligned with the selected engine.
VIEW_ENGINE=php
VIEW_PATH=app/Views
VIEW_PHP_EXTENSION=php
VIEW_TWIG_EXTENSION=twig
VIEW_PLATES_EXTENSION=php
VIEW_LATTE_EXTENSION=latte
VIEW_TWIG_CACHE_PATH=var/cache/twig
VIEW_TWIG_AUTO_RELOAD=true
VIEW_TWIG_DEBUG=false
VIEW_LATTE_TEMP_PATH=var/cache/latte

# Database defaults to PostgreSQL. For other engines and required keys, see docs/database-engines.md.
DB_DEFAULT=pgsql

# PostgreSQL connection settings (default).
PGSQL_HOST=127.0.0.1
PGSQL_PORT=5432
PGSQL_DATABASE=app
PGSQL_USERNAME=postgres
PGSQL_PASSWORD=

# Security feature switches for authentication strategies and CSRF protection.
SECURITY_AUTH_JWT_ENABLED=false
SECURITY_AUTH_OPAQUE_ENABLED=false
SECURITY_AUTH_COOKIE_SESSION_ENABLED=false
SECURITY_AUTH_API_TOKEN_ENABLED=false
SECURITY_AUTH_MTLS_ENABLED=false
SECURITY_CSRF_ENABLED=true

# Global request throttling controls.
SECURITY_RATE_LIMIT_LIMIT=120
SECURITY_RATE_LIMIT_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_BURST=0

# JWT token settings. JWT_SECRET must be set when JWT auth is enabled.
JWT_SECRET=
JWT_LEEWAY_SECONDS=30

# Notifications baseline channel configuration.
NOTIFICATIONS_DEFAULT_CHANNEL=null
NOTIFICATIONS_NULL_ENABLED=true

# Retry policy applied when notification delivery fails.
NOTIFICATIONS_RETRY_MAX_ATTEMPTS=1
NOTIFICATIONS_RETRY_BACKOFF_MS=250
